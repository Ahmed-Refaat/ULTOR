# ─── Ultor Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# .env is gitignored and will never be committed.

# Required — Google Maps Platform (Photorealistic 3D Tiles)
# Get a key at: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Optional — ADSB Exchange via RapidAPI (military aircraft layer)
# Without this key, the military layer falls back to airplanes.live (free, no key needed).
# Get a key at: https://rapidapi.com/adsbexchange-com1-adsbexchange-com1-default/api/adsbexchange-com1
VITE_ADSB_KEY=

# Optional — AISStream.io (live maritime AIS data)
# Without this key, the maritime layer is disabled.
# Get a free key at: https://aisstream.io/
VITE_AISSTREAM_KEY=

# Optional — Cesium Ion token
# Only needed if you use Cesium Ion assets. Leave blank to suppress the default warning.
# Get a free token at: https://cesium.com/ion/
VITE_CESIUM_TOKEN=
